{
  "name": "podscape-electron",
  "version": "1.2.0",
  "description": "Kubernetes management desktop app — Electron + React + TypeScript",
  "main": "./out/main/index.js",
  "author": "Coding Protocols Private Limited <support@codingprotocols.com>",
  "homepage": ".",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "cd go-core && go build ./cmd/podscape-core/ && cd .. && electron-vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "release": "npm run build && electron-builder --publish always",
    "icon:icns": "bash ./scripts/generate-icns.sh resources/icon.png resources/icon.icns",
    "icon:ico": "bash ./scripts/generate-ico.sh resources/icon.png resources/icon.ico"
  },
  "build": {
    "appId": "com.codingprotocols.podscape",
    "productName": "Podscape",
    "copyright": "Copyright © 2025 Coding Protocols Private Limited",
    "afterSign": "scripts/notarize.js",
    "icon": "resources/icon.png",
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.inherit.plist",
      "notarize": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "codingprotocols",
      "repo": "podscape-community"
    },
    "extraResources": [
      {
        "from": "go-core",
        "to": "bin",
        "filter": [
          "podscape-core*"
        ]
      },
      {
        "from": "resources/splash.html",
        "to": "."
      },
      {
        "from": "resources/icon.png",
        "to": "."
      }
    ],
    "asarUnpack": []
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/react-window": "^1.8.8",
    "js-yaml": "^4.1.0",
    "react-window": "^2.2.7",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/notarize": "^3.1.1",
    "@monaco-editor/react": "^4.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.0.18",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "lucide-react": "^0.400.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.2",
    "vite": "^5.3.3",
    "vitest": "^4.0.18",
    "zustand": "^4.5.0"
  }
}
